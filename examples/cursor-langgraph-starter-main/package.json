{
  "name": "cursor-langgraph-starter",
  "version": "1.0.0",
  "description": "A Cursor-optimized starter template for building LangGraph.js applications",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "eval": "tsx src/evals/run.ts",
    "eval:create-dataset": "tsx src/evals/create-dataset.ts",
    "example:streaming": "tsx src/examples/streaming.ts",
    "example:server": "tsx src/examples/server.ts",
    "example:create-agent": "tsx src/examples/create-agent.ts",
    "example:interrupts": "tsx src/examples/interrupts.ts"
  },
  "keywords": [
    "langgraph",
    "langchain",
    "cursor",
    "ai",
    "agents",
    "typescript"
  ],
  "author": "Naoufal El hassnaoui",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.0",
    "@langchain/langgraph": "^1.0.2",
    "@langchain/openai": "^1.1.3",
    "dotenv": "^17.2.3",
    "langchain": "^1.1.1",
    "langsmith": "^0.3.81",
    "zod": "^4.1.13"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.13"
  }
}
