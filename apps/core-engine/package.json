{
	"name": "@vorynth/core-engine",
	"version": "1.4.0",
	"private": true,
	"description": "Vorynth Core Engine — NestJS intelligence runtime (bundled as a Tauri sidecar).",
	"type": "module",
	"main": "dist/main.js",
	"scripts": {
		"dev": "nest start --watch",
		"build": "nest build",
		"start": "node dist/main.js",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx src/db/migrate.ts",
		"db:seed": "tsx src/db/seed.ts",
		"db:studio": "drizzle-kit studio",
		"bundle": "node scripts/bundle-sidecar.mjs"
	},
	"dependencies": {
		"@langchain/anthropic": "^1.5.1",
		"@langchain/core": "^1.1.0",
		"@langchain/google-genai": "^2.2.0",
		"@langchain/langgraph": "^1.0.2",
		"@langchain/openai": "^1.1.3",
		"@nestjs/common": "^11.1.0",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.1.0",
		"@nestjs/platform-fastify": "^11.1.0",
		"@persian-tools/persian-tools": "5.0.0-beta.0",
		"@vorynth/types": "workspace:*",
		"better-sqlite3": "^11.10.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"drizzle-orm": "^0.44.0",
		"fastify": "^5.4.0",
		"langchain": "^1.1.1",
		"reflect-metadata": "^0.2.2",
		"rss-parser": "^3.13.0",
		"rxjs": "^7.8.2",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^24.10.1",
		"@typescript-eslint/eslint-plugin": "^8.48.0",
		"@typescript-eslint/parser": "^8.48.0",
		"@vercel/ncc": "^0.38.3",
		"drizzle-kit": "^0.31.0",
		"eslint": "^9.39.1",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vitest": "^4.0.13"
	}
}
