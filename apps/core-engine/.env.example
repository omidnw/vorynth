# Vorynth Core Engine — environment
# Copy to .env for local dev. In the packaged app these are passed by Tauri.

# Port to bind. In the packaged app, Tauri picks a free port and passes --port.
PORT=4317
HOST=127.0.0.1

# Where the SQLite database + app data live. Defaults to ./data in dev.
VORYNTH_DATA_DIR=./data

# Default LLM provider used during the vertical slice.
# Only one is wired for now; the rest land in Phase 6.
VORYNTH_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS: comma-separated origins. Dev allows the Vite server.
CORS_ORIGIN=http://localhost:5173

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
