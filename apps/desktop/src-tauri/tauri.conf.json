{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Vorynth",
	"version": "1.3.0",
	"identifier": "com.vorynth.desktop",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Vorynth — Personal Intelligence Engine",
				"width": 1440,
				"height": 900,
				"minWidth": 1024,
				"minHeight": 700,
				"resizable": true,
				"fullscreen": false,
				"decorations": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
			"icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
		"resources": [],
		"externalBin": []
	},
	"plugins": {}
}
