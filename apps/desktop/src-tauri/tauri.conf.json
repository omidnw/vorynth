{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Vorynth",
	"version": "1.5.0",
	"identifier": "com.vorynth.desktop",
	"build": {
		"beforeDevCommand": "cd ../../.. && pnpm --filter @vorynth/desktop dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "cd ../../.. && pnpm --filter @vorynth/desktop build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/icon.png",
			"icons/icon.ico",
			"icons/icon.icns"
		],
		"resources": [
			"binaries/"
		],
		"externalBin": []
	},
	"plugins": {}
}
